MONGODB_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/database?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority&appName=kids-after-school

# Admin credentials for the protected /admin area
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Used to sign/verify the httpOnly admin session cookie
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Optional: session lifetime in seconds (default: 86400)
ADMIN_SESSION_MAX_AGE_SECONDS=86400

# Optional: cookie name (default: admin_session)
ADMIN_SESSION_COOKIE_NAME=admin_session
